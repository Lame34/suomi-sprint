    {
      "id": "conversation-001",
      "finnish": "Miten sinulla menee?",
      "english": "How are you doing?",
      "category": "conversation",
      "difficulty": 1,
      "literalTranslation": "How at-you goes?",
      "notes": "Informal. Uses adessive case (sinulla) to express 'at you'.",
      "words": ["miten", "sinä", "mennä"]
    },
    {
      "id": "conversation-002",
      "finnish": "Kiitos, ihan hyvin.",
      "english": "Thanks, quite fine.",
      "category": "conversation",
      "difficulty": 1,
      "literalTranslation": "Thanks, quite well.",
      "notes": "Standard polite reply. 'Ihan' softens the response, meaning 'quite' or 'fairly'.",
      "words": ["kiitos", "hyvin"]
    },
    {
      "id": "conversation-003",
      "finnish": "Entä sinulla?",
      "english": "And you?",
      "category": "conversation",
      "difficulty": 1,
      "literalTranslation": "And-what at-you?",
      "notes": "Informal follow-up. 'Entä' means 'and what about'. Uses adessive case (sinulla).",
      "words": ["sinä"]
    },
    {
      "id": "conversation-004",
      "finnish": "Mitä kuuluu?",
      "english": "What's up? / How are you?",
      "category": "conversation",
      "difficulty": 1,
      "literalTranslation": "What is heard?",
      "notes": "The most common Finnish greeting after 'hei'. Very informal and versatile.",
      "words": ["mikä"]
    },
    {
      "id": "conversation-005",
      "finnish": "Ei erikoista.",
